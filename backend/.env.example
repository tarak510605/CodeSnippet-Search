# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB connection string (local or Atlas)
# Example: mongodb://localhost:27017/code_snippets
MONGODB_URI=mongodb://localhost:27017/code_snippets

# Groq API key for AI search suggestions and code generation
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API key for text embeddings (semantic search)
# Get your key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# JWT secret for signing authentication tokens
# Generate a long random string, e.g.: openssl rand -base64 64
JWT_SECRET=your_jwt_secret_here_make_it_long_random_and_secure

# JWT token expiration (e.g. 7d, 24h)
JWT_EXPIRES_IN=7d

# Optional: CORS origin for production frontend URL
# CORS_ORIGIN=http://localhost:3000
